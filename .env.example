# ─── Supabase (Postgres) ─────────────────────────────────────────────────────
# Project URL + service role key from:
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Server-only — never expose in the browser
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Then run the SQL in supabase/schema.sql (SQL Editor) to create the votes table.

# ─── Arkesel SMS ─────────────────────────────────────────────────────────────
# Use your MAIN SMS API key (OTP does not work with Multiple/sub API keys)
ARKESEL_API_KEY=your_arkesel_api_key_here
ARKESEL_SENDER_ID=ITL Awards

# ─── Admin Dashboard ─────────────────────────────────────────────────────────
ADMIN_SECRET=change_me_to_something_strong
