# ─── Arkesel SMS ─────────────────────────────────────────────────────────────
# Use your MAIN SMS API key (OTP does not work with Multiple/sub API keys)
# Get it from: https://sms.arkesel.com → Dashboard → API Keys
ARKESEL_API_KEY=your_arkesel_api_key_here

# Sender ID shown on recipient's phone (max 11 characters including spaces)
# Must be registered/approved in your Arkesel account
ARKESEL_SENDER_ID=ITL Awards

# OTP: uses Arkesel /api/otp/generate + /api/otp/verify (Arkesel creates & checks the code)
# Thank-you SMS after voting: uses bulk /api/v2/sms/send

# ─── Admin Dashboard ─────────────────────────────────────────────────────────
# Password to access /admin — choose something strong
ADMIN_SECRET=strong_pass
